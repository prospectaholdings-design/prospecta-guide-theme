<section class="py-16 bg-white">
  <div class="container flex flex-col md:flex-row items-center gap-12">
    <div class="w-full md:w-1/2">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | img_url: '800x' }}" alt="{{ section.settings.title }}" class="rounded-lg shadow-xl w-full h-auto">
      {% else %}
        <div class="w-full h-96 bg-gray-200 rounded-lg flex items-center justify-center">
          <span class="text-gray-400">Founder Image Placeholder</span>
        </div>
      {% endif %}
    </div>
    <div class="w-full md:w-1/2">
      <h2 class="text-4xl font-bold mb-6">{{ section.settings.title }}</h2>
      <div class="prose max-w-none text-lg text-gray-700 mb-8">
        {{ section.settings.content }}
      </div>
      {% if section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="btn-primary">{{ section.settings.button_text }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Founder Intro",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Meet the Founder"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Introduce yourself and your vision here.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Founder Image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Founder Intro"
    }
  ]
}
{% endschema %}
