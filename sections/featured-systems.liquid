{%- style -%}
  .featured-systems {
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  .systems-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .systems-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .systems-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 15px;
    color: {{ section.settings.heading_color }};
  }

  .systems-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .system-item {
    background: {{ section.settings.card_bg }};
    border-radius: 12px;
    padding: 40px;
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid {{ section.settings.border_color }};
  }

  .system-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(176, 141, 87, 0.15);
    border-color: {{ section.settings.accent_color }};
  }

  .system-icon {
    font-size: 3rem;
    margin-bottom: 20px;
    min-height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .system-item h3 {
    font-size: 1.4rem;
    margin-bottom: 15px;
    color: {{ section.settings.heading_color }};
  }

  .system-item p {
    font-size: 0.95rem;
    line-height: 1.7;
    opacity: 0.85;
    margin-bottom: 20px;
  }

  .system-link {
    color: {{ section.settings.accent_color }};
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.3s ease;
  }

  .system-link:hover {
    gap: 12px;
  }
{%- endstyle -%}

<section class="featured-systems">
  <div class="systems-container">
    <div class="systems-header">
      <h2>{{ section.settings.title }}</h2>
      {% if section.settings.description != blank %}
        <p>{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <div class="systems-grid">
      {% for block in section.blocks %}
        <div class="system-item">
          <div class="system-icon">{{ block.settings.icon }}</div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.description }}</p>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="system-link">
              Learn More →
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Systems",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Business Systems"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Strategic frameworks designed for modern founders"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F5F1E8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#B08D57"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#E8E4DC"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal (px)",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "system",
      "name": "System",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or text)",
          "default": "⚙️"
        },
        {
          "type": "text",
          "id": "title",
          "label": "System Title",
          "default": "System Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Description of the business system and framework"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Systems",
      "blocks": [
        { "type": "system", "settings": { "icon": "📊", "title": "Business Architecture", "description": "Build scalable organizational systems" } },
        { "type": "system", "settings": { "icon": "💡", "title": "Strategic Clarity", "description": "Define vision and long-term objectives" } },
        { "type": "system", "settings": { "icon": "🚀", "title": "Growth Systems", "description": "Systematize revenue and customer acquisition" } }
      ]
    }
  ]
}
{% endschema %}
