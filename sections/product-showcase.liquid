<section class="py-20 bg-white">
  <div class="container">
    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="text-4xl font-bold mb-4">{{ section.settings.title }}</h2>
        <p class="text-lg text-gray-600 max-w-2xl">{{ section.settings.subtitle }}</p>
      </div>
      {% if section.settings.collection != blank %}
        <a href="{{ section.settings.collection.url }}" class="text-accent-gold font-bold hover:underline">View All Products &rarr;</a>
      {% endif %}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {% assign collection = section.settings.collection %}
      {% if collection != blank %}
        {% for product in collection.products limit: 3 %}
          <div class="group">
            <div class="relative overflow-hidden rounded-lg mb-4 aspect-square bg-gray-100">
              {% if product.featured_image != blank %}
                <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
              {% else %}
                <div class="w-full h-full flex items-center justify-center text-gray-400">Product Image</div>
              {% endif %}
              <a href="{{ product.url }}" class="absolute inset-0 z-10"></a>
            </div>
            <h3 class="text-xl font-bold mb-2">
              <a href="{{ product.url }}" class="hover:text-accent-gold transition-colors">{{ product.title }}</a>
            </h3>
            <p class="text-accent-gold font-medium">{{ product.price | money }}</p>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          <div class="group">
            <div class="relative overflow-hidden rounded-lg mb-4 aspect-square bg-gray-100 flex items-center justify-center text-gray-400">
              Product Placeholder {{ i }}
            </div>
            <h3 class="text-xl font-bold mb-2">Sample Product {{ i }}</h3>
            <p class="text-accent-gold font-medium">$99.00</p>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Premium Solutions"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Strategic frameworks and tools designed for modern founders."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Product Showcase"
    }
  ]
}
{% endschema %}
