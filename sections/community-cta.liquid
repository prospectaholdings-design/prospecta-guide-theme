<section class="py-24 bg-accent-gold text-white overflow-hidden relative">
  <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 opacity-10">
    <svg class="w-96 h-96" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/></svg>
  </div>

  <div class="container relative z-10">
    <div class="max-w-3xl">
      <h2 class="text-5xl font-bold mb-8 leading-tight">{{ section.settings.title }}</h2>
      <p class="text-2xl mb-12 text-white/90 leading-relaxed">{{ section.settings.content }}</p>
      <div class="flex flex-wrap gap-6">
        {% if section.settings.primary_button_link != blank %}
          <a href="{{ section.settings.primary_button_link }}" class="px-10 py-5 bg-dark-bg text-white font-bold text-lg rounded hover:bg-black transition-colors">
            {{ section.settings.primary_button_text }}
          </a>
        {% endif %}
        {% if section.settings.secondary_button_link != blank %}
          <a href="{{ section.settings.secondary_button_link }}" class="px-10 py-5 border-2 border-white text-white font-bold text-lg rounded hover:bg-white hover:text-accent-gold transition-all">
            {{ section.settings.secondary_button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Community CTA",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join the Global Network of Systems Builders"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "Connect with high-level entrepreneurs, share frameworks, and scale your digital ecosystem alongside the world's most effective founders."
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text",
      "default": "Join Community"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Community CTA"
    }
  ]
}
{% endschema %}
