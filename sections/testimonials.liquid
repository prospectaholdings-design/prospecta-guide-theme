<section class="py-20 bg-dark-bg text-white">
  <div class="container">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4">{{ section.settings.title }}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {% for block in section.blocks %}
        <div class="p-8 border border-gray-800 rounded-lg bg-gray-900/50">
          <div class="text-accent-gold mb-6">
            {% for i in (1..5) %}
              <svg class="w-5 h-5 inline-block" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            {% endfor %}
          </div>
          <p class="text-xl italic mb-8 text-gray-300">"{{ block.settings.quote }}"</p>
          <div>
            <p class="font-bold text-lg">{{ block.settings.author }}</p>
            <p class="text-gray-500 text-sm">{{ block.settings.role }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Trusted by Founders"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This framework completely changed how I look at my business architecture."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Alex Rivers"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "SaaS Founder"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
