{% layout 'theme' %}

<section class="section py-breathing">
  <div class="section-contained max-w-5xl">
    <h1 class="section-heading mb-6">{{ blog.title }}</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {% for article in blog.articles %}
        <article class="card">
          {% if article.image %}
            <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title }}" class="rounded mb-4" loading="lazy" />
          {% endif %}
          <h2 class="subsection-heading"><a href="{{ article.url }}">{{ article.title }}</a></h2>
          <p class="text-gray-600">{{ article.excerpt | strip_html }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
