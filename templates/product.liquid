{% layout 'theme' %}

<section class="section py-breathing">
  <div class="section-contained max-w-5xl">
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" class="rounded-lg shadow-lg" loading="lazy" />
        {% endif %}
      </div>

      <div>
        <h1 class="section-heading">{{ product.title }}</h1>
        <p class="text-gray-600 mb-6">{{ product.description | strip_html }}</p>
        <p class="text-2xl font-bold text-amber-700 mb-6">{{ product.price | money }}</p>

        {% if product.available %}
          <form method="post" action="/cart/add">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
            <button type="submit" class="btn-primary">{{ 'buttons.add_to_cart' | t }}</button>
          </form>
        {% else %}
          <p class="text-red-600">Out of stock</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>
