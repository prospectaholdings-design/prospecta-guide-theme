{% layout 'theme' %}

<section class="section py-breathing">
  <div class="section-contained max-w-4xl text-center">
    <h1 class="section-heading mb-4">Search Results</h1>
    {% if search.results_count > 0 %}
      <p class="lead-text mb-8">{{ search.results_count }} results for "{{ search.terms }}"</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {% for result in search.results %}
          <a href="{{ result.url }}" class="card">
            <h3 class="subsection-heading">{{ result.title }}</h3>
            <p class="text-gray-600">{{ result.excerpt | strip_html }}</p>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <p class="text-gray-500">No results found</p>
    {% endif %}
  </div>
</section>
