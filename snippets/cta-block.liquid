<div class="cta-block {{ variant == 'dark' ? 'cta-block-dark' : '' }}">
  <div class="flex items-center justify-between gap-6">
    <div>
      {% if title %}<h3 class="text-2xl font-semibold">{{ title }}</h3>{% endif %}
      {% if text %}<p class="text-gray-700 mt-2">{{ text }}</p>{% endif %}
    </div>
    {% if button_text and button_url %}
      <div>
        <a href="{{ button_url }}" class="btn-primary">{{ button_text }}</a>
      </div>
    {% endif %}
  </div>
</div>
